{
  "expo": {
    "name": "1928 Daily Office",
    "slug": "daily-office-1928",
    "version": "1.0.0",
    "orientation": "portrait",
    "description": "The 1928 American Book of Common Prayer Daily Office for Morning and Evening Prayer",
    "icon": "./icon.png",
    "splash": {
      "image": "./icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F0E8"
    },
    "ios": {
      "bundleIdentifier": "com.increasemather.dailyoffice1928",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": false
      }
    },
    "android": {
      "package": "com.increasemather.dailyoffice1928",
      "adaptiveIcon": {
        "foregroundImage": "./icon.png",
        "backgroundColor": "#F5F0E8"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-notifications"
    ],
    "extra": {
      "privacyPolicyUrl": "https://increasemather.github.io/dailyoffice-privacy",
      "eas": {
        "projectId": "3f951bc2-0fac-4172-9442-a629041790ec"
      }
    }
  }
}
